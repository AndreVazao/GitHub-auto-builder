{
  "expo": {
    "name": "GitHub Auto Builder",
    "slug": "github-auto-builder",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.githubautobuilder.app"
    },
    "android": {
      "package": "com.githubautobuilder.app",
      "permissions": ["SYSTEM_ALERT_WINDOW"]
    }
  }
}
